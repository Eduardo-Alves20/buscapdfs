PORT=3001

# Postgres
# Exemplo:
# DATABASE_URL=postgres://postgres:postgres@localhost:5434/buscapdfs
DATABASE_URL=
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
PGSSLMODE=

# Busca
SEARCH_MAX_RESULTS=1200

# Indexacao
INDEX_CONCURRENCY=2

# Sync de PDFs DOERJ (sistema independente)
DOERJ_ARCHIVE_DIR=./doerj
ARCHIVE_SYNC_ENABLED=true
ARCHIVE_SYNC_RUN_ON_STARTUP=true
ARCHIVE_SYNC_CRON=0 10 * * 1-5
ARCHIVE_SYNC_CRON_SECOND=0 20 * * 1-5
ARCHIVE_SYNC_CRON_SECOND_FORCE=true
ARCHIVE_SYNC_RETRY_PREVIOUS_DAY=true
CRON_TIMEZONE=America/Sao_Paulo

# Se true, o servidor web sobe junto com o daemon do sync
ARCHIVE_SYNC_EMBEDDED_DAEMON=false
