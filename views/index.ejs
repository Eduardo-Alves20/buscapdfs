<%- include('partials/head', { title: 'Busca Historica' }) %>
<body>

<nav class="sidebar">
  <div class="sidebar-brand">
    <div class="d-flex align-items-center gap-2">
      <div class="brand-icon"><i class="bi bi-file-earmark-pdf-fill"></i></div>
      <div>
        <h4>Busca Historica</h4>
        <small>Indice local do DOERJ</small>
      </div>
    </div>
  </div>
  <ul class="nav flex-column">
    <li class="nav-item">
      <a href="<%= withBasePath('/') %>" class="nav-link active">
        <i class="bi bi-search"></i> Busca avancada
      </a>
    </li>
  </ul>
  <div class="sidebar-footer" style="border-top:1px solid rgba(255,255,255,0.08);padding:1rem 1.25rem;">
    <small style="color:#64748b;font-size:0.75rem;">
      Busca em indice PostgreSQL.<br>
      Sem leitura de PDF em tempo real.
    </small>
  </div>
</nav>

<div class="main-content">
  <div class="top-bar">
    <div>
      <h5 class="mb-0 fw-600">Busca Historica</h5>
      <small class="text-muted">Pesquise publicacoes antigas por secao e palavra-chave</small>
    </div>
  </div>

  <div class="page-content">
    <div class="alert alert-info d-flex align-items-start gap-2">
      <i class="bi bi-info-circle-fill mt-1"></i>
      <div>
        Esta tela faz apenas busca historica. Ela nao cria alerta automaticamente.
        O resultado vem do indice em banco para consulta mais rapida.
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header">
        <h6 class="mb-0 fw-600"><i class="bi bi-search me-2 text-primary"></i>Parametros da busca</h6>
      </div>
      <div class="card-body">
        <form id="formBusca">
          <div class="row g-3">
            <div class="col-lg-5">
              <label class="form-label">Palavra ou frase <span class="text-muted">(opcional se houver secao)</span></label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input
                  type="text"
                  id="inputKeyword"
                  class="form-control"
                  placeholder="Ex: gestores do contrato, portaria, auditoria..."
                />
              </div>
              <div class="form-text">Se voce escolher uma ou mais secoes, pode deixar esse campo em branco para ver tudo daquele escopo.</div>
            </div>
            <div class="col-md-3">
              <label class="form-label">Data inicio <span class="text-muted">(opcional)</span></label>
              <input type="date" id="inputDataInicio" class="form-control" />
            </div>
            <div class="col-md-3">
              <label class="form-label">Data fim <span class="text-muted">(opcional)</span></label>
              <input type="date" id="inputDataFim" class="form-control" />
            </div>
            <div class="col-md-1 d-flex align-items-end">
              <button type="submit" class="btn btn-primary w-100" id="btnBuscar">
                <i class="bi bi-search"></i>
              </button>
            </div>
            <div class="col-12">
              <label class="form-label">Secoes do Diario</label>
              <div class="section-picker">
                <div class="form-check mb-2">
                  <input class="form-check-input" type="checkbox" id="all-sections" checked>
                  <label class="form-check-label fw-500" for="all-sections">Todo o DOERJ</label>
                </div>
                <div class="section-checkbox-list is-disabled" id="section-options">
                  <% sectionOptions.forEach(option => { %>
                    <label class="section-check">
                      <input
                        class="form-check-input section-option"
                        type="checkbox"
                        value="<%= option.id %>"
                        disabled
                      >
                      <span><%= option.label %></span>
                    </label>
                  <% }) %>
                </div>
                <div class="form-text mt-2">Marque uma ou mais secoes. Se "Todo o DOERJ" estiver ativo, o filtro de secao e ignorado.</div>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>

    <div id="searchStatus" style="display:none;" class="card mb-3">
      <div class="card-body py-3">
        <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
          <div class="d-flex align-items-center gap-2">
            <div id="statusSpinner" class="spinner-border spinner-border-sm text-primary" role="status"></div>
            <span id="statusText" class="fw-500 small text-muted">Consultando indice...</span>
          </div>
          <div class="d-flex align-items-center gap-2">
            <span class="badge bg-primary-soft text-primary" id="foundBadge" style="display:none;">
              <i class="bi bi-check-circle me-1"></i><span id="foundCount">0</span> resultado(s)
            </span>
            <button type="button" class="btn btn-sm btn-outline-danger" id="btnCancelar" style="display:none;">
              <i class="bi bi-x-circle me-1"></i>Cancelar
            </button>
          </div>
        </div>
        <div class="progress" style="height:6px;">
          <div
            id="progressBar"
            class="progress-bar progress-bar-striped progress-bar-animated"
            role="progressbar"
            style="width:0%"
          ></div>
        </div>
      </div>
    </div>

    <div id="resultsSection" style="display:none;">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
          <h6 class="mb-0 fw-600">
            <i class="bi bi-list-ul me-2 text-primary"></i>
            Resultados
            <span class="badge bg-primary ms-1" id="resultCountBadge">0</span>
          </h6>
          <div class="d-flex align-items-center gap-2 flex-wrap" id="resultTags"></div>
        </div>
        <div class="card-body p-0">
          <div id="emptyState" class="empty-state" style="display:none;">
            <i class="bi bi-file-earmark-x"></i>
            <p>Nenhuma publicacao encontrada para os criterios informados.</p>
          </div>
          <div id="truncatedInfo" class="alert alert-warning rounded-0 border-0 mb-0" style="display:none;">
            Foram exibidos os primeiros <strong id="maxResultsLabel">0</strong> resultados. Refine os filtros para reduzir o volume.
          </div>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="resultsTable" style="display:none;">
              <thead>
                <tr>
                  <th>Data</th>
                  <th>Arquivo</th>
                  <th>Secao</th>
                  <th>Mencoes</th>
                  <th>Resumo</th>
                  <th>Abrir</th>
                </tr>
              </thead>
              <tbody id="resultsTbody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="resultModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <div>
          <h5 class="modal-title mb-1">Resumo da materia</h5>
          <small class="text-muted">Clique no botao azul para abrir o PDF oficial local</small>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>
      <div class="modal-body">
        <div class="alert-meta-grid mb-4">
          <div>
            <small class="text-muted d-block">Data do DO</small>
            <strong id="modal-data">-</strong>
          </div>
          <div>
            <small class="text-muted d-block">Arquivo</small>
            <strong id="modal-arquivo">-</strong>
          </div>
          <div>
            <small class="text-muted d-block">Secao</small>
            <strong id="modal-secao">-</strong>
          </div>
          <div>
            <small class="text-muted d-block">Mencoes encontradas</small>
            <strong id="modal-mencoes">-</strong>
          </div>
        </div>
        <div>
          <small class="text-muted d-block mb-2">Resumo encontrado</small>
          <div class="highlighted-reading" id="modal-snippet">-</div>
        </div>
      </div>
      <div class="modal-footer">
        <a href="#" class="btn btn-outline-primary disabled" id="modal-open-pdf" target="_blank" rel="noopener noreferrer">
          <i class="bi bi-box-arrow-up-right me-1"></i>Abrir PDF
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/scripts') %>
<script>
const BASE_PATH = '<%= basePath %>';
function withBasePath(pathname) {
  const normalizedPath = pathname.startsWith('/') ? pathname : `/${pathname}`;
  if (!BASE_PATH) return normalizedPath;
  return normalizedPath === '/' ? `${BASE_PATH}/` : `${BASE_PATH}${normalizedPath}`;
}

const allSectionsCheckbox = document.getElementById('all-sections');
const sectionInputs = [...document.querySelectorAll('.section-option')];
const sectionsWrap = document.getElementById('section-options');
const resultModal = new bootstrap.Modal(document.getElementById('resultModal'));
let activeSource = null;
let rowData = [];

function syncSectionState() {
  if (allSectionsCheckbox.checked) {
    sectionInputs.forEach(input => {
      input.checked = false;
      input.disabled = true;
    });
    sectionsWrap.classList.add('is-disabled');
    return;
  }
  sectionInputs.forEach(input => { input.disabled = false; });
  sectionsWrap.classList.remove('is-disabled');
}

allSectionsCheckbox.addEventListener('change', syncSectionState);
sectionInputs.forEach(input => {
  input.addEventListener('change', () => {
    allSectionsCheckbox.checked = !sectionInputs.some(item => item.checked);
    syncSectionState();
  });
});

function setSearching(on) {
  const btn = document.getElementById('btnBuscar');
  const cancel = document.getElementById('btnCancelar');
  const spin = document.getElementById('statusSpinner');
  const bar = document.getElementById('progressBar');

  btn.disabled = on;
  btn.innerHTML = on ? '<span class="spinner-border spinner-border-sm"></span>' : '<i class="bi bi-search"></i>';
  cancel.style.display = on ? '' : 'none';
  spin.style.display = on ? '' : 'none';
  bar.classList.toggle('progress-bar-animated', on);
  bar.classList.toggle('progress-bar-striped', on);
}

function resetResults() {
  rowData = [];
  document.getElementById('resultsTbody').innerHTML = '';
  document.getElementById('resultsTable').style.display = 'none';
  document.getElementById('emptyState').style.display = 'none';
  document.getElementById('truncatedInfo').style.display = 'none';
  document.getElementById('resultCountBadge').textContent = '0';
  document.getElementById('progressBar').style.width = '0%';
  document.getElementById('foundBadge').style.display = 'none';
  document.getElementById('foundCount').textContent = '0';
}

function openModal(item) {
  document.getElementById('modal-data').textContent = item.date || '-';
  document.getElementById('modal-arquivo').textContent = item.filename || '-';
  document.getElementById('modal-secao').textContent = item.sectionLabel || '-';
  document.getElementById('modal-mencoes').textContent = item.count != null ? `${item.count} mencao(oes)` : '-';
  document.getElementById('modal-snippet').innerHTML = item.highlightedSnippet || '-';

  const btn = document.getElementById('modal-open-pdf');
  btn.href = item.pdfUrl || '#';
  btn.classList.toggle('disabled', !item.pdfUrl);
  resultModal.show();
}

function addRow(item) {
  item.pdfUrl = `${withBasePath('/pdf')}?file=${encodeURIComponent(item.relativePath)}`;
  const idx = rowData.length;
  rowData.push(item);

  const countHtml = item.count != null
    ? `<span class="badge bg-warning-soft text-warning fw-600">${item.count}</span>`
    : '<span class="text-muted small">-</span>';

  const tr = document.createElement('tr');
  tr.className = 'clickable-row';
  tr.tabIndex = 0;
  tr.dataset.idx = idx;
  tr.title = 'Clique para ver o resumo da materia';
  tr.innerHTML = `
    <td><span class="badge bg-secondary-soft text-secondary">${item.date || '-'}</span></td>
    <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${item.filename || '-'}</td>
    <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
      <span class="badge bg-info-soft text-info">${item.sectionLabel || '-'}</span>
    </td>
    <td style="text-align:center">${countHtml}</td>
    <td style="max-width:420px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${item.highlightedSnippet || '-'}</td>
    <td>
      <a href="${item.pdfUrl}" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" data-row-ignore="true">
        <i class="bi bi-box-arrow-up-right"></i>
      </a>
    </td>
  `;

  tr.addEventListener('click', event => {
    if (event.target.closest('[data-row-ignore="true"]')) return;
    openModal(rowData[Number(tr.dataset.idx)]);
  });

  tr.addEventListener('keydown', event => {
    if (event.key !== 'Enter' && event.key !== ' ') return;
    event.preventDefault();
    openModal(rowData[Number(tr.dataset.idx)]);
  });

  document.getElementById('resultsTbody').appendChild(tr);
  document.getElementById('resultsTable').style.display = '';
  document.getElementById('emptyState').style.display = 'none';
}

function startSearch() {
  const keyword = document.getElementById('inputKeyword').value.trim();
  const dataInicio = document.getElementById('inputDataInicio').value;
  const dataFim = document.getElementById('inputDataFim').value;
  const sections = sectionInputs.filter(input => input.checked).map(input => input.value);

  if (!keyword && !sections.length) {
    Swal.fire({
      icon: 'warning',
      title: 'Falta informar a busca',
      text: 'Digite uma palavra-chave ou selecione ao menos uma secao especifica.'
    });
    return;
  }

  if (activeSource) {
    activeSource.close();
    activeSource = null;
  }

  resetResults();
  document.getElementById('statusText').textContent = 'Consultando indice...';
  document.getElementById('searchStatus').style.display = '';
  document.getElementById('resultsSection').style.display = '';
  setSearching(true);

  const tagsEl = document.getElementById('resultTags');
  tagsEl.innerHTML = '';
  if (!sections.length) tagsEl.innerHTML += '<span class="badge bg-primary-soft text-primary">Todo o DOERJ</span>';
  if (sections.length) tagsEl.innerHTML += `<span class="badge bg-info-soft text-info">${sections.length} secao(oes)</span>`;
  if (keyword) tagsEl.innerHTML += `<span class="badge bg-primary-soft text-primary">${keyword}</span>`;
  if (dataInicio || dataFim) tagsEl.innerHTML += `<span class="badge bg-secondary-soft text-secondary">${dataInicio || '...'} -> ${dataFim || '...'}</span>`;

  const params = new URLSearchParams();
  if (keyword) params.set('keyword', keyword);
  if (dataInicio) params.set('dataInicio', dataInicio);
  if (dataFim) params.set('dataFim', dataFim);
  sections.forEach(section => params.append('sections', section));

  activeSource = new EventSource(`${withBasePath('/buscar')}?${params.toString()}`);
  activeSource.onmessage = event => {
    let data;
    try { data = JSON.parse(event.data); } catch (_) { return; }

    if (data.type === 'scanning') {
      document.getElementById('statusText').textContent = 'Consultando indice no banco...';
    }

    if (data.type === 'result') {
      addRow(data);
      document.getElementById('resultCountBadge').textContent = String(rowData.length);
      document.getElementById('foundCount').textContent = String(rowData.length);
      document.getElementById('foundBadge').style.display = '';
    }

    if (data.type === 'progress') {
      const pct = data.total ? Math.round((data.done / data.total) * 100) : 0;
      document.getElementById('progressBar').style.width = `${pct}%`;
      document.getElementById('statusText').textContent = `Carregando resultados... ${data.done.toLocaleString('pt-BR')} / ${data.total.toLocaleString('pt-BR')}`;
    }

    if (data.type === 'done') {
      if (activeSource) {
        activeSource.close();
        activeSource = null;
      }
      setSearching(false);
      document.getElementById('progressBar').style.width = '100%';
      document.getElementById('statusText').textContent = `Concluido - ${data.found.toLocaleString('pt-BR')} resultado(s)`;
      if (!rowData.length) document.getElementById('emptyState').style.display = '';
      if (data.truncated) {
        document.getElementById('maxResultsLabel').textContent = String(data.maxResults || rowData.length);
        document.getElementById('truncatedInfo').style.display = '';
      }
    }

    if (data.type === 'error') {
      if (activeSource) {
        activeSource.close();
        activeSource = null;
      }
      setSearching(false);
      Swal.fire({ icon: 'error', title: 'Erro na busca', text: data.message });
      document.getElementById('statusText').textContent = 'Falha ao consultar indice.';
    }
  };

  activeSource.onerror = () => {
    if (activeSource) {
      activeSource.close();
      activeSource = null;
    }
    setSearching(false);
    document.getElementById('statusText').textContent = 'Conexao interrompida. Tente novamente.';
  };
}

document.getElementById('formBusca').addEventListener('submit', event => {
  event.preventDefault();
  startSearch();
});

document.getElementById('btnCancelar').addEventListener('click', () => {
  if (activeSource) {
    activeSource.close();
    activeSource = null;
  }
  setSearching(false);
  document.getElementById('statusText').textContent = 'Busca cancelada.';
});
</script>
</body>
</html>
