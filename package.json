{
  "name": "busca-pdfs-doerj",
  "version": "1.0.0",
  "description": "Busca de texto dentro dos PDFs locais do DOERJ",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "archive:sync": "node scripts/sync-doerj.js",
    "archive:backfill": "node scripts/backfill-doerj.js",
    "archive:daemon": "node scripts/archive-daemon.js",
    "db:docker:up": "docker compose up -d",
    "db:docker:down": "docker compose down",
    "db:docker:logs": "docker compose logs -f postgres",
    "db:init": "node scripts/init-db.js",
    "db:index": "node scripts/index-doerj.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.58.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
